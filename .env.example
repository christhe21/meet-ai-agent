# Meet AI Agent - Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# Required for a session
MEET_URL=https://meet.google.com/xxx-yyyy-zzz
DISPLAY_NAME=AI Coach
PERSONA=gordon

# Provider selection
STT_PROVIDER=deepgram          # deepgram | gladia | captions
LLM_PROVIDER=openai            # openai | anthropic | gemini
TTS_PROVIDER=elevenlabs        # elevenlabs | openai | cartesia

# API Keys
DEEPGRAM_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=

# Behavior
MIN_LONELY_SECONDS=3.0
VIRTUAL_MIC_DEVICE=            # e.g. "CABLE Input (VB-Audio Virtual Cable)" on Windows
